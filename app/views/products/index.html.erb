<div class="navbar bg-dark text-white d-flex justify-content-center p-4 mb-5">
    <h1> Estoque </h1>
</div>

    <div class="w-50 m-auto text-center">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                <th scope="col">ID</th>
                <th scope="col">Nome</th>
                <th scope="col">Preço</th>
                <th scope="col">Quantidade</th>
                <th scope="col">Ação</th>
                </tr>
            </thead>
            <tbody>
                <% @products.each do |product| %>
                    <% if product.name.present? && product.price.present? && product.quantity.present? %>
                        <tr>
                        <th> <%= product.id %> </th>
                        <td> <%= product.name %> </td>
                        <td> <%= product.price %> </td>
                        <td> <%= product.quantity %> </td>
                        <td>
                            <%= link_to product_path(product), class: "btn btn-primary" do %>
                            <i class="fa-regular fa-eye"></i> <% end %>
                            <%= link_to edit_product_path(product), class: "btn btn-warning" do %>
                            <i class="fa-regular fa-pen-to-square"></i> <% end %>
                            <%= link_to product_path(product), class: "btn btn-danger", data: {
                            turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir este produto?"} do %>
                            <i class="fa-regular fa-trash-can"></i> <% end %>
                            </td>
                        </tr>
                    <% end %>
                <% end %>
            </tbody>
        </table>
    </div>

<div class="row">
    <div class="col-1 m-auto">
        <%= link_to new_product_path, class: "btn btn-success" do %>
        <i class="fa-solid fa-plus"></i>
        <% end %>
    </div>
</div>
